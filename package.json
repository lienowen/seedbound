    "autopilot:complete": "node scripts/autopilot.mjs --complete"
  },
  "dependencies": {
    "@vitejs/plugin-react": "5.0.4",
    "phaser": "^3.90.0",
    "pixi.js": "^8.19.0",
    "pngjs": "^7.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "vite": "6.4.2"
